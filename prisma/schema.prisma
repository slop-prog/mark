generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Bookmark {
  id        String   @id @default(cuid())
  url       String
  domain    String
  title     String
  tag       String   @default("tools")
  screenshot String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("bookmarks")
}
